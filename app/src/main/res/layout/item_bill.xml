<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dash_card_bg"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/billIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_save"
        android:padding="6dp"
        android:background="@drawable/priority_tag_bg"
        app:tint="@color/sidebar_bg"
        android:contentDescription="Bill Icon" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/billIcon"
        android:layout_marginStart="12dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/billTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bill Title"
            android:textColor="@color/sidebar_bg"
            android:textStyle="bold"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/billDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due: 20 May 2026"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:gravity="end"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/billAmountAndStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="₹0\nPending"
            android:gravity="end"
            android:textColor="@color/sidebar_bg"
            android:textSize="12sp" />
        <Button
            android:id="@+id/payButton"
            android:layout_width="80dp"
            android:layout_height="32dp"
            android:background="@drawable/route_button_bg"
            android:text="@string/pay"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </LinearLayout>
</RelativeLayout>
