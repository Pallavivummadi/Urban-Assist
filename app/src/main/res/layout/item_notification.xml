<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <ImageView
        android:id="@+id/notifIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/priority_tag_bg"
        android:backgroundTint="#FFF9E6"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_agenda"
        app:tint="#F1C40F"
        android:contentDescription="Notification Icon" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/notifIcon"
        android:layout_marginStart="16dp"
        android:orientation="vertical">
        
        <TextView
            android:id="@+id/notifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notification Title"
            android:textColor="@color/sidebar_bg"
            android:textStyle="bold"
            android:textSize="14sp" />
        
        <TextView
            android:id="@+id/notifMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Notification Message"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
        
        <TextView
            android:id="@+id/notifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Time"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            tools:ignore="SmallSp" />
    </LinearLayout>
</RelativeLayout>
