<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dash_card_bg"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/contactIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:padding="6dp"
        android:background="@drawable/priority_tag_bg"
        app:tint="#1ABC9C"
        android:contentDescription="Contact" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/contactIcon"
        android:layout_marginStart="12dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/contactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Name"
            android:textColor="@color/sidebar_bg"
            android:textStyle="bold"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/contactPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+91 00000 00000"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/callButton"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@android:drawable/ic_menu_call"
        app:tint="#1ABC9C"
        android:contentDescription="Call"
        android:clickable="true"
        android:focusable="true" />
</RelativeLayout>
